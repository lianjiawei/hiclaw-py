# ========================================
# HiClaw 配置模板
# 复制此文件为 .env 并填入你的实际配置
# cp .env.example .env
# ========================================

# ========================================
# Telegram 机器人配置
# ========================================
# Telegram Bot Token，从 @BotFather 获取
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# 机器人所有者 ID（Telegram user ID）
OWNER_ID=your_telegram_user_id_here

# ========================================
# Agent Provider 配置
# ========================================
# 选择 AI 提供商：claude 或 openai
# AGENT_PROVIDER=claude
AGENT_PROVIDER=openai

# ========================================
# Claude / Anthropic 配置
# ========================================
# Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# 自定义 API 端点（可选，用于代理或兼容 API）
ANTHROPIC_BASE_URL=https://your-anthropic-proxy.com
# 默认模型
ANTHROPIC_MODEL=your_claude_model_here

# DeepSeek 模型分组配置（可选）
ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-pro
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-pro

# Claude Code 运行行为控制
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
CLAUDE_CODE_DISABLE_NONSTREAMING_FALLBACK=1
CLAUDE_CODE_EFFORT_LEVEL=medium

# ========================================
# OpenAI 配置
# ========================================
# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here
# 自定义 API 端点（可选）
OPENAI_BASE_URL=https://your-openai-proxy.com/v1
# 默认模型
OPENAI_MODEL=gpt-4o-mini

# OpenAI 图片生成配置
OPENAI_IMAGE_API_KEY=your_openai_image_api_key_here
OPENAI_IMAGE_BASE_URL=https://your-image-proxy.com/v1
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=auto
OPENAI_IMAGE_OUTPUT_FORMAT=png
OPENAI_IMAGE_INCLUDE_OPTIONAL_PARAMS=0
OPENAI_IMAGE_TIMEOUT_SECONDS=120

# ========================================
# Dashboard 监控面板配置
# ========================================
# 监听地址：0.0.0.0 允许外部访问，127.0.0.1 仅本地访问
# 云服务器必须设置为 0.0.0.0 才能从公网访问
HICLAW_DASHBOARD_HOST=0.0.0.0
# 监听端口
HICLAW_DASHBOARD_PORT=8765

# ========================================
# 工作区与定时任务配置
# ========================================
# 工作区目录路径
WORKSPACE_DIR=./workspace
# 定时任务检查间隔（秒）
SCHEDULER_INTERVAL_SECONDS=5

# ========================================
# 语音转文字配置
# ========================================
# 语音识别提供商：none（关闭）或 vosk（本地 Vosk 模型）
ASR_PROVIDER=none
# Vosk 模型目录路径（当 ASR_PROVIDER=vosk 时需要）
# VOSK_MODEL_DIR=/path/to/vosk-model

# ========================================
# Telegram 请求超时与启动重试配置
# ========================================
TELEGRAM_CONNECT_TIMEOUT=30
TELEGRAM_READ_TIMEOUT=30
TELEGRAM_WRITE_TIMEOUT=30
TELEGRAM_POOL_TIMEOUT=30
TELEGRAM_POLLING_TIMEOUT=30
TELEGRAM_BOOTSTRAP_RETRIES=5
TELEGRAM_RESTART_DELAY_SECONDS=10

# ========================================
# 飞书机器人通道配置
# ========================================
# 飞书自建应用 App ID（长连接模式，必须）
FEISHU_APP_ID=your_feishu_app_id_here
# 飞书自建应用 App Secret（长连接模式，必须）
FEISHU_APP_SECRET=your_feishu_app_secret_here
# 允许使用的飞书用户 open_id，逗号分隔；留空表示不限制用户
FEISHU_ALLOWED_OPEN_IDS=
# 允许使用的飞书会话 chat_id，逗号分隔；留空表示不限制会话
FEISHU_ALLOWED_CHAT_IDS=
# 飞书会话隔离前缀
FEISHU_SESSION_SCOPE_PREFIX=feishu
# 收到消息后是否先回复"正在处理"：1 开启，0 关闭
FEISHU_REPLY_PROCESSING_MESSAGE=1

# ========================================
# Tavily 联网搜索配置
# ========================================
# Tavily API Key，在 https://app.tavily.com 注册获取
TAVILY_API_KEY=your_tavily_api_key_here
# 搜索深度：basic（快速）或 advanced（深度）
TAVILY_SEARCH_DEPTH=basic
# 单次搜索返回的最大结果数
TAVILY_MAX_RESULTS=5

# ========================================
# 其他配置
# ========================================
# 是否显示工具调用追踪：1 开启，0 关闭
SHOW_TOOL_TRACE=0
# 会话超时时间（秒），默认 86400（24 小时）
SESSION_TIMEOUT_SECONDS=86400
# 能力热加载监控：1 开启，0 关闭
CAPABILITY_WATCHER_ENABLED=1
CAPABILITY_WATCHER_INTERVAL_SECONDS=1.0

# ========================================
# Agent Cluster 配置
# ========================================
# 是否启用多 Agent 集群协调模式：1 开启，0 关闭
AGENT_CLUSTER_ENABLED=0
# 是否启用 reviewer 复核角色：1 开启，0 关闭
AGENT_CLUSTER_REVIEW_ENABLED=1
# 用户自定义 Agent JSON 定义目录；留空则使用 capabilities/agents
# AGENT_DEFINITIONS_DIR=./capabilities/agents
# 是否启用真实多 Agent 任务编排执行链：1 开启，0 关闭
AGENT_CLUSTER_ORCHESTRATOR_ENABLED=0
# 是否启用 planner 动态生成多 Agent DAG 任务计划：1 开启，0 关闭
AGENT_CLUSTER_DYNAMIC_PLANNER_ENABLED=0
# dashboard 中保留的 cluster 事件条数上限
AGENT_CLUSTER_MAX_EVENTS=40
